# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp

# Python (for future scripts/validate.py)
__pycache__/
*.pyc
.venv/
venv/

# Local Codex working state
.codex/

# Local generated memory stores
memory/cognee/
memory/candidates/

# Orchestrator runtime outputs (generated by CLI)
runtime/orchestrator/runs/**
!runtime/orchestrator/runs/.gitkeep
runtime/orchestrator/latest_*.json
runtime/dispatch/*
!runtime/dispatch/.gitkeep
runtime/dispatch/previews/*
!runtime/dispatch/previews/.gitkeep
runtime/unittest_last_run.txt
runtime/unittest_result.txt

# Dispatch preview run artifacts (generated by preview_dispatch.py)
logs/dispatch-*.jsonl
