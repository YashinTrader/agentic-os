{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-os.local/schemas/codex_human_approval_request.schema.json",
  "title": "CodexHumanApprovalRequest",
  "type": "object",
  "required": [
    "request_id",
    "activation_id",
    "adapter_id",
    "reviewed_commit_sha",
    "canary_contract_hash",
    "command_contract_hash",
    "context_bundle_hash",
    "worktree_requirement",
    "maximum_runs",
    "timeout_seconds",
    "expected_network_usage",
    "expected_cost_exposure",
    "allowed_file_change",
    "forbidden_operations",
    "approval_expiry_minutes",
    "approval_level_required",
    "approver_type_required",
    "requested_at",
    "status"
  ],
  "properties": {
    "request_id": { "type": "string" },
    "activation_id": { "type": "string" },
    "adapter_id": { "type": "string", "const": "codex-restricted" },
    "reviewed_commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "canary_contract_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "command_contract_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "context_bundle_hash": { "type": "string" },
    "worktree_requirement": { "type": "string" },
    "maximum_runs": { "type": "integer", "const": 1 },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "expected_network_usage": { "type": "string" },
    "expected_cost_exposure": { "type": "string" },
    "allowed_file_change": { "type": "string" },
    "forbidden_operations": { "type": "array", "items": { "type": "string" } },
    "approval_expiry_minutes": { "type": "integer", "minimum": 1 },
    "approval_level_required": { "type": "string", "const": "human" },
    "approver_type_required": { "type": "string", "const": "human" },
    "requested_at": { "type": "string" },
    "status": { "type": "string", "const": "awaiting_human_decision" },
    "version": { "type": "string" },
    "statement": { "type": "string" }
  },
  "additionalProperties": false
}