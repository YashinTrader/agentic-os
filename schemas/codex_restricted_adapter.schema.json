{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-os.local/schemas/codex_restricted_adapter.schema.json",
  "title": "CodexRestrictedAdapter",
  "type": "object",
  "required": [
    "id",
    "display_name",
    "adapter_type",
    "provider",
    "executable",
    "required_clis",
    "minimum_version",
    "active",
    "supports_preview",
    "supports_dry_run",
    "supports_execution",
    "promotion_state",
    "writes_files",
    "worktree_required",
    "network_required",
    "secrets_required",
    "mcp_required",
    "approval_level",
    "risk_level",
    "timeout_seconds",
    "maximum_timeout_seconds",
    "allowed_subcommands",
    "allowed_flags",
    "forbidden_flags",
    "environment_allowlist",
    "environment_denylist",
    "output_format",
    "context_bundle_required",
    "handoff_required",
    "rollback_required"
  ],
  "properties": {
    "id": { "const": "codex-restricted" },
    "supports_execution": { "const": false },
    "promotion_state": { "const": "restricted_candidate" },
    "approval_level": { "const": "human" },
    "worktree_required": { "const": true },
    "network_required": { "const": true },
    "secrets_required": { "const": true },
    "mcp_required": { "const": false }
  },
  "additionalProperties": true
}