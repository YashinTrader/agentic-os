{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-os.local/schemas/codex_activation_manifest.schema.json",
  "title": "CodexActivationManifest",
  "type": "object",
  "required": [
    "activation_id",
    "version",
    "adapter_id",
    "adapter_config_hash",
    "promotion_state",
    "supports_execution",
    "execution_scope",
    "maximum_runs",
    "runs_consumed",
    "reviewed_commit_sha",
    "cli_version",
    "cli_help_hash",
    "command_contract_hash",
    "canary_contract_hash",
    "context_bundle_hash",
    "worktree_policy_hash",
    "environment_policy_hash",
    "approval_policy_hash",
    "emergency_disable_policy_hash",
    "human_approval_required",
    "human_approval_reference",
    "claude_review_required",
    "claude_review_reference",
    "phase3_7b_authorization_required",
    "phase3_7b_authorization_reference",
    "created_at",
    "expires_at",
    "status",
    "disabled_reason"
  ],
  "properties": {
    "activation_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["1.0", "2.0"] },
    "adapter_id": { "type": "string", "const": "codex-restricted" },
    "adapter_config_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "promotion_state": { "type": "string" },
    "supports_execution": { "type": "boolean" },
    "execution_scope": { "type": "string", "const": "canary_only" },
    "maximum_runs": { "type": "integer", "const": 1 },
    "runs_consumed": { "type": "integer", "minimum": 0, "maximum": 1 },
    "reviewed_commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "cli_version": { "type": "string" },
    "cli_help_hash": { "type": "string" },
    "command_contract_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "canary_contract_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "context_bundle_hash": { "type": "string" },
    "worktree_policy_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "environment_policy_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "approval_policy_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "emergency_disable_policy_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "human_approval_required": { "type": "boolean", "const": true },
    "human_approval_reference": { "type": "string" },
    "claude_review_required": { "type": "boolean", "const": true },
    "claude_review_reference": { "type": "string" },
    "phase3_7b_authorization_required": { "type": "boolean", "const": true },
    "phase3_7b_authorization_reference": { "type": "string" },
    "created_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "awaiting_claude_review",
        "awaiting_human_approval",
        "human_approved",
        "activation_ready",
        "active_canary_only",
        "active",
        "completed",
        "suspended",
        "revoked",
        "suspended_pending_review"
      ]
    },
    "disabled_reason": { "type": "string" },
    "live_run_authorized": { "type": "boolean" }
  },
  "additionalProperties": true
}