# Agentic OS Phase 2.1 local Cognee profile.
# Copy values into your local environment or .env file when running Cognee.
# This profile is a dry-run bootstrap profile; ingestion stays disabled.

AGENTIC_OS_MEMORY_BACKEND="cognee"
AGENTIC_OS_MEMORY_PROFILE="local"
AGENTIC_OS_ENABLE_CLOUD_PROVIDERS="false"
AGENTIC_OS_INGESTION_ENABLED="false"

# LLM: local Ollama, OpenAI-compatible endpoint.
LLM_PROVIDER="ollama"
LLM_MODEL="llama3.1:8b"
LLM_ENDPOINT="http://localhost:11434/v1"
LLM_API_KEY="ollama"

# Embeddings: local CPU Fastembed.
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS="384"

# Storage: all local single-user defaults.
GRAPH_DATABASE_PROVIDER="kuzu"
VECTOR_DB_PROVIDER="lancedb"
DB_PROVIDER="sqlite"
DB_NAME="agentic_os_cognee"
SYSTEM_ROOT_DIRECTORY="./memory/cognee/system"
DATA_ROOT_DIRECTORY="./memory/cognee/data"
